---
import Logo from './Logo.astro';

const currentYear = new Date().getFullYear();
---

<footer class="relative bg-charcoal-950 border-t border-burgundy-900/10 pt-20 pb-10 px-4 overflow-hidden">
  <!-- Subtle decorative backgrounds -->
  <div class="absolute inset-0 bg-grid-cyber opacity-10 pointer-events-none z-0"></div>
  
  <div class="max-w-7xl mx-auto relative z-10">
    
    <!-- Top section: Brand, Links, and Newsletter -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12 mb-16">
      
      <!-- Brand & Ram Logo Column -->
      <div class="lg:col-span-1.5 flex flex-col items-start">
        <a href="#hero" class="flex items-center gap-3 mb-6 group focus:outline-none select-none">
          <Logo className="w-10 h-10 group-hover:scale-110" glow={false} />
          <span class="font-mono font-bold text-xl tracking-tight text-white">
            &lt;<span class="text-gold-500">Carnero</span><span class="text-burgundy-500">.Dev</span>/&gt;
          </span>
        </a>
        <p class="font-sans text-sm text-brand-white/60 leading-relaxed mb-6 max-w-sm">
          Organizado por la carrera de Tecnologías de la Información y Comunicaciones (TICs) del ITR Roque. 
          Fomentando la innovación, el desarrollo de software de calidad y la cultura de hackeo ético en Guanajuato.
        </p>
        
        <!-- Social Icon Buttons -->
        <div class="flex items-center gap-4">
          <!-- GitHub -->
          <a href="#github" class="w-10 h-10 rounded-xl glassmorphism bg-charcoal-900/50 flex items-center justify-center text-brand-white/60 hover:text-white hover:border-gold-500/30 transition-all duration-300" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
          </a>
          <!-- Discord -->
          <a href="#discord" class="w-10 h-10 rounded-xl glassmorphism bg-charcoal-900/50 flex items-center justify-center text-brand-white/60 hover:text-white hover:border-gold-500/30 transition-all duration-300" aria-label="Discord">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994.021-.041.001-.09-.041-.106a13.094 13.094 0 0 1-1.873-.894.077.077 0 0 1-.008-.128c.126-.093.252-.19.372-.287a.075.075 0 0 1 .077-.011c3.92 1.793 8.18 1.793 12.061 0a.073.073 0 0 1 .078.009c.12.099.246.195.373.289a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.894.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.955 2.418-2.156 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.156-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.156 2.418z"/></svg>
          </a>
          <!-- Instagram -->
          <a href="#instagram" class="w-10 h-10 rounded-xl glassmorphism bg-charcoal-900/50 flex items-center justify-center text-brand-white/60 hover:text-white hover:border-gold-500/30 transition-all duration-300" aria-label="Instagram">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </a>
          <!-- LinkedIn -->
          <a href="#linkedin" class="w-10 h-10 rounded-xl glassmorphism bg-charcoal-900/50 flex items-center justify-center text-brand-white/60 hover:text-white hover:border-gold-500/30 transition-all duration-300" aria-label="LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" /></svg>
          </a>
        </div>
      </div>

      <!-- Quick Navigation Column -->
      <div class="flex flex-col items-start md:items-stretch pl-0 lg:pl-8">
        <h4 class="font-mono text-xs text-gold-500 uppercase tracking-widest mb-6">[ NAVEGACIÓN ]</h4>
        <ul class="space-y-3">
          <li>
            <a href="#hero" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Inicio</a>
          </li>
          <li>
            <a href="#about" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Sobre el Evento</a>
          </li>
          <li>
            <a href="#desafio" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">El Desafío</a>
          </li>
          <li>
            <a href="#timeline" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Calendario</a>
          </li>
          <li>
            <a href="#prizes" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Premios</a>
          </li>
        </ul>
      </div>

      <!-- Legal / Documents Column -->
      <div class="flex flex-col items-start md:items-stretch">
        <h4 class="font-mono text-xs text-gold-500 uppercase tracking-widest mb-6">[ LEGALES ]</h4>
        <ul class="space-y-3">
          <li>
            <a href="/bases" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Bases del Evento</a>
          </li>
          <li>
            <a href="#code-of-conduct" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Código de Conducta</a>
          </li>
          <li>
            <a href="#privacy" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Aviso de Privacidad</a>
          </li>
          <li>
            <a href="mailto:soporte@carnero.dev" class="font-sans text-sm text-brand-white/70 hover:text-gold-400 transition-colors">Soporte Técnico</a>
          </li>
        </ul>
      </div>

      <!-- Newsletter Column -->
      <div class="flex flex-col items-start">
        <h4 class="font-mono text-xs text-gold-500 uppercase tracking-widest mb-6">[ HACKER NEWSLETTER ]</h4>
        <p class="font-sans text-xs text-brand-white/60 leading-relaxed mb-4">
          Suscríbete para recibir notificaciones sobre la apertura de registros, liberación de retos y actualizaciones de logística.
        </p>
        
        <!-- Newsletter Input Widget -->
        <form class="w-full space-y-2">
          <div class="relative w-full overflow-hidden rounded-xl border border-burgundy-900/30 focus-within:border-gold-500/30 transition-all duration-300">
            <input 
              type="email" 
              placeholder="root@tu_email.com" 
              required
              class="w-full bg-charcoal-900/60 font-mono text-xs px-4 py-3 text-brand-white placeholder-brand-white/30 focus:outline-none"
            />
          </div>
          <button 
            type="submit" 
            class="w-full font-mono text-xs font-bold py-3 rounded-xl bg-burgundy-800 text-white hover:bg-burgundy-700 hover:shadow-[0_0_15px_rgba(90,16,34,0.3)] transition-all duration-300 active:scale-95"
          >
            [ SUSCRIBIRSE ]
          </button>
        </form>
      </div>

    </div>

    <!-- Bottom section: copyright, host and technology stack credits -->
    <div class="border-t border-burgundy-900/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4 font-mono text-[10px] text-brand-white/40">
      <div>
        © {currentYear} &lt;Carnero.Dev/&gt; • Todos los derechos reservados.
      </div>
      
      <div class="flex items-center gap-1.5">
        <span>Diseñado y Desarrollado con</span>
        <svg class="w-3.5 h-3.5 text-burgundy-500 hover:scale-110 transition-transform cursor-pointer" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <span>para TICs ITR • Roque</span>
      </div>

      <div class="flex items-center gap-1 opacity-70">
        <span>Stack:</span>
        <span class="text-gold-500 hover:underline cursor-pointer">Astro 5</span>
        <span>•</span>
        <span class="text-gold-500 hover:underline cursor-pointer">Tailwind v4</span>
        <span>•</span>
        <span class="text-gold-500 hover:underline cursor-pointer">TS</span>
      </div>
    </div>

  </div>
</footer>
