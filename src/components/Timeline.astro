---
const steps = [
  {
    phase: 'STEP 01',
    title: 'Registro y Acreditación',
    datetime: 'Viernes 16 Oct • 08:00 AM',
    description: 'Entrega de hack-packs oficiales, gafetes inteligentes de acceso y asignación de estaciones de trabajo.',
    badge: 'Logística'
  },
  {
    phase: 'STEP 02',
    title: 'Ceremonia de Inauguración',
    datetime: 'Viernes 16 Oct • 09:30 AM',
    description: 'Kickoff oficial, presentación de mentores, patrocinadores y revelación de los retos específicos por track.',
    badge: 'Inicio'
  },
  {
    phase: 'STEP 03',
    title: 'Talleres de Tecnología',
    datetime: 'Viernes 16 Oct • 11:00 AM',
    description: 'Sesiones técnicas express de IA aplicada, despliegues rápidos y ciberseguridad dictados por expertos de la industria.',
    badge: 'Workshops'
  },
  {
    phase: 'STEP 04',
    title: 'Hacking & Mentoring',
    datetime: 'Viernes 16 Oct • 12:00 PM - Sábado 17 Oct • 11:59 PM',
    description: 'Desarrollo ininterrumpido. Rondas de mentoría técnica y de negocios cada 6 horas para pivotar y consolidar proyectos.',
    badge: 'Desarrollo'
  },
  {
    phase: 'STEP 05',
    title: 'Demo Day & Pitches',
    datetime: 'Domingo 18 Oct • 09:00 AM',
    description: 'Presentación final de proyectos ante el jurado calificador. Pitch técnico de 3 minutos + 2 minutos de preguntas y respuestas.',
    badge: 'Evaluación'
  },
  {
    phase: 'STEP 06',
    title: 'Clausura y Premiación',
    datetime: 'Domingo 18 Oct • 02:00 PM',
    description: 'Anuncio de ganadores, entrega de trofeos premium, cheques simbólicos y kits de patrocinadores.',
    badge: 'Premiación'
  }
];
---

<section 
  id="timeline" 
  class="relative py-28 px-4 overflow-hidden bg-charcoal-900 border-t border-burgundy-900/10"
>
  <div class="absolute inset-0 bg-dot-matrix opacity-10 pointer-events-none"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    
    <!-- Title -->
    <div class="text-center mb-24">
      <h2 class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-3">[ SCHEDULE TRACK ]</h2>
      <p class="text-4xl md:text-5xl font-display font-black text-white tracking-tight">
        Línea de Tiempo del Evento
      </p>
      <div class="w-20 h-1 bg-gradient-to-r from-gold-500 to-burgundy-600 mx-auto mt-6 rounded-full"></div>
      
      <p class="mt-6 font-sans text-brand-white/60 max-w-2xl mx-auto text-base">
        3 días llenos de código, aprendizaje, mentores expertos y competencia al más alto nivel tecnológico.
      </p>
    </div>

    <!-- Timeline Body (Vertical Design) -->
    <div class="relative">
      
      <!-- Central Circuit Line -->
      <div class="absolute left-4 md:left-1/2 top-4 bottom-4 w-[2px] -translate-x-1/2 bg-gradient-to-b from-gold-500 via-burgundy-800 to-gold-500 opacity-30 pointer-events-none hidden md:block"></div>
      <div class="absolute left-6 top-4 bottom-4 w-[2px] bg-gradient-to-b from-gold-500 via-burgundy-800 to-gold-500 opacity-30 pointer-events-none md:hidden"></div>

      <!-- Steps List -->
      <div class="space-y-12 md:space-y-20">
        {steps.map((step, idx) => {
          const isEven = idx % 2 === 0;
          return (
            <div class={`relative flex flex-col md:flex-row items-stretch ${isEven ? 'md:flex-row-reverse' : ''}`}>
              
              <!-- Timeline node in center -->
              <!-- Desktop Node -->
              <div class="absolute left-4 md:left-1/2 top-8 -translate-x-1/2 flex items-center justify-center pointer-events-none z-20">
                <div class="w-7 h-7 rounded-full bg-charcoal-950 border-2 border-gold-500 flex items-center justify-center shadow-[0_0_10px_rgba(217,164,65,0.4)] animate-glow-pulse-gold">
                  <div class="w-2.5 h-2.5 rounded-full bg-burgundy-600"></div>
                </div>
              </div>

              <!-- Content Card Container (takes half width on desktop) -->
              <div class="w-full md:w-[45%] pl-12 md:pl-0 flex flex-col justify-center">
                <div class="glassmorphism bg-charcoal-900/40 p-6 md:p-8 rounded-3xl border border-burgundy-800/10 hover:border-gold-500/25 transition-all duration-300 hover:shadow-[0_0_25px_rgba(217,164,65,0.05)] relative group">
                  <!-- Diagonal top-corner label -->
                  <span class="absolute top-4 right-4 font-mono text-[9px] text-brand-white/40 tracking-widest">{step.phase}</span>
                  
                  <!-- Badge -->
                  <span class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-mono font-semibold bg-burgundy-950/60 border border-burgundy-800/30 text-burgundy-400 mb-3 tracking-wide uppercase">
                    {step.badge}
                  </span>

                  <!-- Title -->
                  <h3 class="font-display font-bold text-xl text-white group-hover:text-gold-400 transition-colors mb-2">
                    {step.title}
                  </h3>

                  <!-- Datetime with clock SVG -->
                  <div class="flex items-center gap-2 text-gold-500 font-mono text-xs mb-4">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>{step.datetime}</span>
                  </div>

                  <!-- Description -->
                  <p class="font-sans text-sm text-brand-white/60 leading-relaxed">
                    {step.description}
                  </p>
                </div>
              </div>

              <!-- Empty spacer to align grid layout on desktop -->
              <div class="hidden md:block w-[45%]"></div>
            </div>
          );
        })}
      </div>

    </div>

  </div>
</section>
