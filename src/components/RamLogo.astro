---
interface Props {
  className?: string;
  glow?: boolean;
}

const { className = "w-24 h-24", glow = true } = Astro.props;
---

<svg 
  xmlns="http://www.w3.org/2000/svg" 
  viewBox="0 0 500 500" 
  class={`${className} ${glow ? 'glow-gold drop-shadow-[0_0_20px_rgba(217,164,65,0.25)]' : ''}`}
  fill="none"
>
  <defs>
    <!-- Core Gradients -->
    <linearGradient id="gold-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#F1D082" />
      <stop offset="50%" stop-color="#D9A441" />
      <stop offset="100%" stop-color="#76561B" />
    </linearGradient>

    <linearGradient id="burgundy-grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#BD3256" />
      <stop offset="50%" stop-color="#5A1022" />
      <stop offset="100%" stop-color="#2D050E" />
    </linearGradient>

    <linearGradient id="glow-grad" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#5A1022" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#D9A441" stop-opacity="0.8" />
    </linearGradient>

    <!-- Glowing Filters -->
    <filter id="neon-glow" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="6" result="blur" />
      <feMerge>
        <feMergeNode in="blur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <!-- BACKGROUND DECORATIVE HEXAGONS -->
  <g class="opacity-15">
    <polygon points="250,50 380,125 380,275 250,350 120,275 120,125" stroke="url(#gold-grad)" stroke-width="1.5" stroke-dasharray="8,6" />
    <polygon points="250,20 420,118 420,312 250,410 80,312 80,118" stroke="url(#burgundy-grad)" stroke-width="1" />
  </g>

  <!-- CIRCUIT / PCB TRACES IN BACKGROUND -->
  <g class="opacity-30" stroke="url(#gold-grad)" stroke-width="1.5" stroke-linecap="round">
    <!-- Left PCB branches -->
    <path d="M 100 150 L 50 150 L 30 180" />
    <circle cx="30" cy="180" r="3" fill="#D9A441" />
    
    <path d="M 80 250 L 30 250 L 15 220" />
    <circle cx="15" cy="220" r="3" fill="#D9A441" />

    <path d="M 120 300 L 70 350 L 70 390" />
    <circle cx="70" cy="390" r="3" fill="#D9A441" />

    <!-- Right PCB branches -->
    <path d="M 400 150 L 450 150 L 470 180" />
    <circle cx="470" cy="180" r="3" fill="#D9A441" />
    
    <path d="M 420 250 L 470 250 L 485 220" />
    <circle cx="485" cy="220" r="3" fill="#D9A441" />

    <path d="M 380 300 L 430 350 L 430 390" />
    <circle cx="430" cy="390" r="3" fill="#D9A441" />
  </g>

  <!-- RAM HORNS (HIGH-TECH MECHANICAL SPIRALS WITH SEGMENTS) -->
  <g filter="url(#neon-glow)">
    <!-- LEFT HORN SEGMENTS -->
    <!-- Segment 1: Base -->
    <path d="M 190 140 C 150 90, 80 100, 60 160 C 45 200, 70 250, 110 270 C 120 275, 140 250, 140 240 C 110 230, 90 190, 100 160 C 110 130, 160 120, 185 155 Z" fill="url(#burgundy-grad)" stroke="url(#gold-grad)" stroke-width="1.5" />
    <!-- Segment 2: Curved Middle -->
    <path d="M 110 270 C 150 290, 200 250, 210 200 C 215 170, 200 155, 190 160 C 195 190, 170 220, 140 225 C 125 228, 115 240, 110 270 Z" fill="url(#gold-grad)" opacity="0.85" />
    <!-- Segment 3: Horn Ridge Details -->
    <path d="M 160 120 L 140 105 M 130 135 L 105 125 M 110 170 L 80 170 M 112 210 L 90 220 M 130 245 L 115 265" stroke="url(#gold-grad)" stroke-width="2" stroke-linecap="round" />
    
    <!-- RIGHT HORN SEGMENTS -->
    <!-- Segment 1: Base -->
    <path d="M 310 140 C 350 90, 420 100, 440 160 C 455 200, 430 250, 390 270 C 380 275, 360 250, 360 240 C 390 230, 410 190, 400 160 C 390 130, 340 120, 315 155 Z" fill="url(#burgundy-grad)" stroke="url(#gold-grad)" stroke-width="1.5" />
    <!-- Segment 2: Curved Middle -->
    <path d="M 390 270 C 350 290, 300 250, 290 200 C 285 170, 300 155, 310 160 C 305 190, 330 220, 360 225 C 375 228, 385 240, 390 270 Z" fill="url(#gold-grad)" opacity="0.85" />
    <!-- Segment 3: Horn Ridge Details -->
    <path d="M 340 120 L 360 105 M 370 135 L 395 125 M 390 170 L 420 170 M 388 210 L 410 220 M 370 245 L 385 265" stroke="url(#gold-grad)" stroke-width="2" stroke-linecap="round" />
  </g>

  <!-- ANGULAR CYBER HEAD MESH (GEOMETRIC SOFTWARE-INSPIRED SHAPES) -->
  <g filter="url(#neon-glow)">
    <!-- Forehead -->
    <polygon points="250,110 300,160 200,160" fill="url(#burgundy-grad)" stroke="url(#gold-grad)" stroke-width="2" />
    <polygon points="250,110 280,75 220,75" fill="none" stroke="url(#gold-grad)" stroke-width="1.5" stroke-dasharray="4,2" />

    <!-- Center Nose Bridge -->
    <polygon points="250,110 280,160 250,290 220,160" fill="url(#burgundy-grad)" stroke="url(#gold-grad)" stroke-width="2" />

    <!-- Cheeks Left -->
    <polygon points="200,160 220,160 220,290 170,220" fill="url(#burgundy-grad)" stroke="url(#gold-grad)" stroke-width="1.5" opacity="0.9" />
    
    <!-- Cheeks Right -->
    <polygon points="300,160 280,160 280,290 330,220" fill="url(#burgundy-grad)" stroke="url(#gold-grad)" stroke-width="1.5" opacity="0.9" />

    <!-- Muzzle / Snout -->
    <polygon points="220,290 280,290 250,360" fill="url(#gold-grad)" stroke="url(#gold-grad)" stroke-width="2" />
    <polygon points="230,320 270,320 250,360" fill="#0F0F13" />

    <!-- Cyber Tech Details / Nodes on Snout -->
    <line x1="250" y1="290" x2="250" y2="340" stroke="url(#gold-grad)" stroke-width="1.5" />
    <circle cx="250" cy="340" r="3.5" fill="#D9A441" />

    <!-- Eyes (Glow Gold LEDs) -->
    <!-- Left Eye -->
    <polygon points="215,175 240,175 230,187 210,183" fill="#D9A441" stroke="#F1D082" stroke-width="1" />
    <!-- Right Eye -->
    <polygon points="285,175 260,175 270,187 290,183" fill="#D9A441" stroke="#F1D082" stroke-width="1" />
  </g>

  <!-- CHIN & LOWER NODE LINKS -->
  <g class="opacity-80">
    <path d="M 250 360 L 250 420" stroke="url(#gold-grad)" stroke-width="2" />
    <circle cx="250" cy="420" r="5" fill="#D9A441" filter="url(#neon-glow)" />
    
    <path d="M 250 420 L 200 450 L 150 450" stroke="url(#burgundy-grad)" stroke-width="1.5" stroke-dasharray="3,3" />
    <circle cx="150" cy="450" r="3" fill="#BD3256" />

    <path d="M 250 420 L 300 450 L 350 450" stroke="url(#burgundy-grad)" stroke-width="1.5" stroke-dasharray="3,3" />
    <circle cx="350" cy="450" r="3" fill="#BD3256" />
  </g>

  <!-- CODE / BRACKET OVERLAYS (SUBTLE) -->
  <g class="opacity-40" fill="none" stroke="url(#gold-grad)" stroke-width="1">
    <!-- Left bracket '{' -->
    <path d="M 75 100 L 60 100 L 60 120 L 50 125 L 60 130 L 60 150 L 75 150" />
    <text x="35" y="143" fill="#D9A441" font-family="monospace" font-size="10" font-weight="bold">CODE</text>

    <!-- Right bracket '}' -->
    <path d="M 425 100 L 440 100 L 440 120 L 450 125 L 440 130 L 440 150 L 425 150" />
    <text x="445" y="143" fill="#D9A441" font-family="monospace" font-size="10" font-weight="bold">CTRL</text>
  </g>

  <!-- CORE EMITTER / CENTER HEX NODE -->
  <polygon points="250,140 263,148 263,163 250,170 237,163 237,148" fill="url(#gold-grad)" opacity="0.8" filter="url(#neon-glow)" />
</svg>
