---
const guests = [
  {
    name: 'Por Confirmar',
    role: 'Ponente Especial',
    company: 'Compañía Tech Líder',
    specialty: 'Desarrollo de Software & Arquitectura',
    avatarGrad: 'from-gold-600 via-gold-500 to-burgundy-900',
    initials: '?'
  },
  {
    name: 'Por Confirmar',
    role: 'Juez del Evento',
    company: 'Innovador de Tecnología',
    specialty: 'Inteligencia Artificial & Datos',
    avatarGrad: 'from-burgundy-800 via-burgundy-600 to-charcoal-900',
    initials: '?'
  },
  {
    name: 'Por Confirmar',
    role: 'Ponente Especial',
    company: 'Compañía Tech Líder',
    specialty: 'Cloud, DevOps & Infraestructura',
    avatarGrad: 'from-gold-500 via-burgundy-800 to-gold-400',
    initials: '?'
  },
  {
    name: 'Por Confirmar',
    role: 'Juez del Evento',
    company: 'Experto en Seguridad',
    specialty: 'Ciberseguridad & Sistemas Robustos',
    avatarGrad: 'from-charcoal-800 via-gold-600 to-burgundy-900',
    initials: '?'
  }
];
---

<section 
  id="invitados" 
  class="relative py-28 px-4 overflow-hidden bg-charcoal-900 border-t border-burgundy-900/10"
>
  <div class="absolute inset-0 bg-dot-matrix opacity-10 pointer-events-none z-0"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    
    <!-- Title -->
    <div class="text-center mb-24">
      <h2 class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-3">[ GUEST GRID ]</h2>
      <p class="text-4xl md:text-5xl font-display font-black text-white tracking-tight">
        Invitados & Jueces
      </p>
      <div class="w-20 h-1 bg-gradient-to-r from-gold-500 to-burgundy-600 mx-auto mt-6 rounded-full"></div>
      
      <p class="mt-6 font-sans text-brand-white/60 max-w-2xl mx-auto text-base leading-relaxed">
        Próximamente anunciaremos a los ingenieros de software, diseñadores y líderes de la industria que nos acompañarán como ponentes y jueces especiales durante el hackathon.
      </p>
    </div>

    <!-- Guests Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {guests.map((g) => (
        <div class="glassmorphism bg-charcoal-900/40 rounded-3xl border border-burgundy-800/10 hover:border-gold-500/30 transition-all duration-500 hover:shadow-[0_0_35px_rgba(217,164,65,0.08)] hover:-translate-y-1 group relative overflow-hidden flex flex-col justify-between h-full p-6">
          
          <!-- Circuit graphic details behind -->
          <div class="absolute inset-x-0 bottom-0 h-1/2 bg-[linear-gradient(to_top,rgba(217,164,65,0.02)_0%,transparent_100%)] pointer-events-none"></div>

          <div>
            <!-- Abstract Cyber Avatar / Profile Graphics -->
            <div class="relative w-full aspect-square rounded-2xl overflow-hidden mb-6 flex items-center justify-center border border-charcoal-800 bg-charcoal-950 group-hover:border-gold-500/20 transition-colors">
              <!-- High-contrast tech gradient matrix -->
              <div class={`absolute inset-3 rounded-xl bg-gradient-to-tr ${g.avatarGrad} opacity-10 blur-md group-hover:scale-105 transition-transform duration-500`}></div>
              <div class={`absolute inset-3 rounded-xl bg-gradient-to-tr ${g.avatarGrad} opacity-15 group-hover:opacity-30 transition-opacity duration-500`}></div>
              
              <!-- Digital elements on avatar -->
              <div class="absolute inset-0 bg-grid-cyber opacity-10"></div>
              
              <!-- Monogram Display -->
              <span class="relative z-10 font-mono text-4xl md:text-5xl font-black text-brand-white/40 group-hover:scale-110 group-hover:text-gold-400/80 transition-all duration-300">
                {g.initials}
              </span>

              <!-- Cyber corner brackets inside avatar frame -->
              <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-gold-500/30"></div>
              <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-gold-500/30"></div>
            </div>

            <!-- Guest Info -->
            <h3 class="font-display font-bold text-lg text-white/50 mb-1 group-hover:text-gold-400 transition-colors italic">
              {g.name}
            </h3>
            <p class="font-mono text-xs text-gold-500/70 mb-1.5">{g.role}</p>
            
            <div class="flex items-center gap-1.5 mb-4">
              <!-- Company Badge -->
              <span class="inline-block px-2.5 py-0.5 rounded-md text-[10px] font-mono font-medium bg-charcoal-950 border border-charcoal-800 text-brand-white/40 select-none">
                {g.company}
              </span>
            </div>

            <!-- Specialty text -->
            <p class="font-sans text-xs text-brand-white/40 leading-relaxed border-t border-burgundy-900/10 pt-4 mb-4">
              <span class="font-mono text-gold-500/50 block uppercase text-[9px] tracking-widest mb-1 select-none">ESPECIALIDAD SUGERIDA:</span>
              {g.specialty}
            </p>
          </div>

          <!-- Bottom tech indicator decoration -->
          <div class="flex items-center gap-2 border-t border-burgundy-900/10 pt-4 font-mono text-[9px] text-brand-white/30 uppercase select-none">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-gold-500/30 animate-pulse"></span>
            GUEST_STATUS_PENDING
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
