---
const mentors = [
  {
    name: 'Dr. Marcus Vance',
    role: 'AI Research Scientist',
    company: 'Google DeepMind',
    specialty: 'Agentes Autónomos & LLMs',
    avatarGrad: 'from-gold-600 via-gold-500 to-burgundy-900',
    initials: 'MV',
    socials: {
      github: '#',
      linkedin: '#',
      twitter: '#'
    }
  },
  {
    name: 'Mtra. Elena Rostova',
    role: 'Security Architect',
    company: 'Hack The Box partner',
    specialty: 'Pentesting & Red Teaming',
    avatarGrad: 'from-burgundy-800 via-burgundy-600 to-charcoal-900',
    initials: 'ER',
    socials: {
      github: '#',
      linkedin: '#',
      twitter: '#'
    }
  },
  {
    name: 'Ing. Carlos Morado',
    role: 'Senior Developer Advocate',
    company: 'Vercel / Next.js contributor',
    specialty: 'Web Perf & Edge Serverless',
    avatarGrad: 'from-gold-500 via-burgundy-800 to-gold-400',
    initials: 'CM',
    socials: {
      github: '#',
      linkedin: '#',
      twitter: '#'
    }
  },
  {
    name: 'Dr. Hiroshi Tanaka',
    role: 'IoT Hardware Lead',
    company: 'Arduino Labs',
    specialty: 'Firmware & Telemetría Física',
    avatarGrad: 'from-charcoal-800 via-gold-600 to-burgundy-900',
    initials: 'HT',
    socials: {
      github: '#',
      linkedin: '#',
      twitter: '#'
    }
  }
];
---

<section 
  id="speakers" 
  class="relative py-28 px-4 overflow-hidden bg-charcoal-900 border-t border-burgundy-900/10"
>
  <div class="absolute inset-0 bg-dot-matrix opacity-10 pointer-events-none z-0"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    
    <!-- Title -->
    <div class="text-center mb-24">
      <h2 class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-3">[ MENTOR GRID ]</h2>
      <p class="text-4xl md:text-5xl font-display font-black text-white tracking-tight">
        Mentores & Conferencistas
      </p>
      <div class="w-20 h-1 bg-gradient-to-r from-gold-500 to-burgundy-600 mx-auto mt-6 rounded-full"></div>
      
      <p class="mt-6 font-sans text-brand-white/60 max-w-2xl mx-auto text-base">
        Aprende, consulta y valida tu proyecto con ingenieros y arquitectos de software líderes en la industria tecnológica.
      </p>
    </div>

    <!-- Mentors Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {mentors.map((m) => (
        <div class="glassmorphism bg-charcoal-900/40 rounded-3xl border border-burgundy-800/10 hover:border-gold-500/30 transition-all duration-500 hover:shadow-[0_0_35px_rgba(217,164,65,0.08)] hover:-translate-y-1 group relative overflow-hidden flex flex-col justify-between h-full p-6">
          
          <!-- Circuit graphic details behind -->
          <div class="absolute inset-x-0 bottom-0 h-1/2 bg-[linear-gradient(to_top,rgba(217,164,65,0.02)_0%,transparent_100%)] pointer-events-none"></div>

          <div>
            <!-- Abstract Cyber Avatar / Profile Graphics -->
            <div class="relative w-full aspect-square rounded-2xl overflow-hidden mb-6 flex items-center justify-center border border-charcoal-800 bg-charcoal-950 group-hover:border-gold-500/20 transition-colors">
              <!-- High-contrast tech gradient matrix -->
              <div class={`absolute inset-3 rounded-xl bg-gradient-to-tr ${m.avatarGrad} opacity-30 blur-md group-hover:scale-105 transition-transform duration-500`}></div>
              <div class={`absolute inset-3 rounded-xl bg-gradient-to-tr ${m.avatarGrad} opacity-20 group-hover:opacity-40 transition-opacity duration-500`}></div>
              
              <!-- Digital elements on avatar -->
              <div class="absolute inset-0 bg-grid-cyber opacity-15"></div>
              
              <!-- Monogram Display -->
              <span class="relative z-10 font-mono text-4xl md:text-5xl font-black text-white/90 group-hover:scale-110 group-hover:text-gold-400 transition-all duration-300">
                {m.initials}
              </span>

              <!-- Cyber corner brackets inside avatar frame -->
              <div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-gold-500/30"></div>
              <div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-gold-500/30"></div>
            </div>

            <!-- Mentor Info -->
            <h3 class="font-display font-bold text-lg text-white mb-1 group-hover:text-gold-400 transition-colors">
              {m.name}
            </h3>
            <p class="font-mono text-xs text-gold-500 mb-1.5">{m.role}</p>
            
            <div class="flex items-center gap-1.5 mb-4">
              <!-- Company Badge -->
              <span class="inline-block px-2.5 py-0.5 rounded-md text-[10px] font-mono font-medium bg-charcoal-950 border border-charcoal-800 text-brand-white/70">
                {m.company}
              </span>
            </div>

            <!-- Specialty text -->
            <p class="font-sans text-xs text-brand-white/50 leading-relaxed border-t border-burgundy-900/10 pt-4 mb-4">
              <span class="font-mono text-gold-500/60 block uppercase text-[9px] tracking-widest mb-1">ESPECIALIDAD:</span>
              {m.specialty}
            </p>
          </div>

          <!-- Social links / hover reveal -->
          <div class="flex items-center gap-3 border-t border-burgundy-900/10 pt-4">
            <a href={m.socials.github} class="text-brand-white/40 hover:text-gold-500 transition-colors p-1" aria-label="GitHub">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.53 1.032 1.53 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
            </a>
            <a href={m.socials.linkedin} class="text-brand-white/40 hover:text-gold-500 transition-colors p-1" aria-label="LinkedIn">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
