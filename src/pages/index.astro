---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import RegisterModal from '../components/RegisterModal.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Challenge from '../components/Challenge.astro';
import Evaluation from '../components/Evaluation.astro';
import Deliverables from '../components/Deliverables.astro';
import Rules from '../components/Rules.astro';
import Timeline from '../components/Timeline.astro';
import Prizes from '../components/Prizes.astro';
import Speakers from '../components/Speakers.astro';
import Faq from '../components/Faq.astro';
import Sponsors from '../components/Sponsors.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- Global Blur Floating Navigation -->
  <Navbar />
  
  <!-- Interactive Registration Modal -->
  <RegisterModal />

  <!-- Single-Page Scrolling Content -->
  <main class="flex-grow">
    <!-- Hero Segment with Particles & Countdown -->
    <Hero />

    <!-- About Segment explaining Core Values -->
    <About />

    <!-- El Desafío (Challenge) Section -->
    <Challenge />

    <!-- Criterios de Evaluación (Evaluation Criteria) Section -->
    <Evaluation />

    <!-- ¿Qué Deben Entregar? (Deliverables) Section -->
    <Deliverables />

    <!-- Bases del Evento (Rules Summary) Section -->
    <Rules />

    <!-- Timeline Segment describing Schedule Milestones -->
    <Timeline />

    <!-- Prizes Segment detailing Esports Podiums -->
    <Prizes />

    <!-- Speakers Segment showcasing Industry Specialists -->
    <Speakers />

    <!-- FAQ Accordion Segment -->
    <Faq />

    <!-- Sponsors Segment showing Corporate Ties -->
    <Sponsors />
  </main>

  <!-- Dynamic Footer Section -->
  <Footer />
</Layout>
